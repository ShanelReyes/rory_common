MICTLANX_CLIENT_ID="test_client_id"
MICTLANX_TIMEOUT=100
MICTLANX_API_VERSION="4"
MICTLANX_MAX_WORKERS=4
MICTLANX_BUCKET_ID="rory"
MICTLANX_OUTPUT_PATH="/rory/mictlanx"
MICTLANX_PROTOCOL="http"
MICTLANX_URI="mictlanx://mictlanx-router-0@localhost:63666?api_version=4&protocol=http"
MICTLANX_DEBUG=0
RORY_KEYS_PATH="/rory/keys"
RORY_COMMON_CTX_FILENAME = "ctx"
RORY_COMMON_PUBKEY_FILENAME = "pubkey"
RORY_COMMON_SECRETKEY_FILENAME = "secretkey"
RORY_COMMON_SECURITY_LEVEL=128
RORY_COMMON_RECORDS=10
RORY_COMMON_ATTRIBUTES=10